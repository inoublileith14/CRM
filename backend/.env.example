PORT=3001
FRONTEND_URL=http://localhost:3000

JWT_SECRET=cambia-este-secreto-en-produccion

# Project URL only — do NOT add /rest/v1 (Supabase Dashboard → Settings → API → Project URL)
SUPABASE_URL=https://tu-proyecto.supabase.co
# Settings → API → "anon public"
SUPABASE_ANON_KEY=tu-anon-key
# Settings → API → "service_role" (secret) — NO uses la anon key aquí
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

ADMIN_EMAIL=admin@cocount.com
ADMIN_PASSWORD=Cocount

# Coconut AI chatbot (OpenAI)
OPENAI_API_KEY=sk-proj-tu-clave
# Uses OpenAI Responses API (POST /v1/responses). Examples: gpt-5.4-mini, gpt-4o-mini
OPENAI_MODEL=gpt-5.4-mini

# Google Calendar OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
# Must match an authorized redirect URI in Google Cloud (frontend callback route)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# WhatsApp Cloud API (Meta) — dev: only test recipient numbers receive messages
WHATSAPP_PHONE_NUMBER_ID=
PHONE_NUMBER=
TOKEN_WHATSAPP=
WHATSAPP_TEMPLATE_NAME=coconut_luxury_flats
WHATSAPP_TEMPLATE_LANGUAGE=es
# Set to true only if the template has a dynamic URL button (link is in {{3}} body var by default)
WHATSAPP_TEMPLATE_HAS_URL_BUTTON=false
WHATSAPP_TEMPLATE_URL_BUTTON_INDEX=0
WHATSAPP_SENDER_NAME=
WHATSAPP_GRAPH_VERSION=v22.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=coconut_whatsapp_verify_2026
